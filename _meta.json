{
  "name": "aipioneer-publisher",
  "version": "1.0.0",
  "description": "AIPioneer 公众号发布器 - 一键完成素材获取、改写、排版、发布",
  "author": "AI Pioneer",
  "tags": ["wechat", "publisher", "writing", "khazix", "自媒体", "公众号"],
  "triggers": [
    "帮我发布这篇文章",
    "用AI Pioneer排版发布",
