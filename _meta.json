    "一键发布到公众号",
    "发公众号"
  ],
  "requires": {
    "services": [
      {
        "name": "wechat-typesetting",
        "url": "http://localhost:3000",
        "description": "微信排版和推送服务"
      }
    ],
    "tools": [
      {
        "name": "browser",
        "description": "浏览器自动化工具（用于 X/Twitter 获取）"
      }
    ],
    "env": [
      "WECHAT_APPID",
      "WECHAT_SECRET"
    ]
  },
